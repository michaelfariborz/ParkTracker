@page "/admin"
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer

@using ParkTracker.Data.Models
@using ParkTracker.Services

@inject IParkService ParkService

<PageTitle>Admin — Parks</PageTitle>

<h1>Park Management</h1>

<h2 class="h5 mt-4">Add New Park</h2>
<EditForm Model="model" OnValidSubmit="HandleAddPark" class="row g-3 mb-5">
    <DataAnnotationsValidator />
    @if (successMessage is not null)
    {
        <div class="col-12"><div class="alert alert-success">@successMessage</div></div>
    }
    @if (errorMessage is not null)
    {
        <div class="col-12"><div class="alert alert-danger">@errorMessage</div></div>
    }
    <div class="col-md-4">
        <label class="form-label">Name</label>
        <InputText class="form-control" @bind-Value="model.Name" />
        <ValidationMessage For="() => model.Name" />
    </div>
    <div class="col-md-3">
        <label class="form-label">State</label>
        <InputText class="form-control" @bind-Value="model.State" />
        <ValidationMessage For="() => model.State" />
    </div>
    <div class="col-md-2">
        <label class="form-label">Latitude</label>
        <InputNumber class="form-control" @bind-Value="model.Latitude" />
        <ValidationMessage For="() => model.Latitude" />
    </div>
    <div class="col-md-2">
        <label class="form-label">Longitude</label>
        <InputNumber class="form-control" @bind-Value="model.Longitude" />
        <ValidationMessage For="() => model.Longitude" />
    </div>
    <div class="col-12">
        <label class="form-label">Description (optional)</label>
        <InputText class="form-control" @bind-Value="model.Description" />
    </div>
    <div class="col-12">
        <button type="submit" class="btn btn-primary">Add Park</button>
    </div>
</EditForm>

<h2 class="h5">All Parks (@parks.Count)</h2>
<table class="table table-striped table-sm">
    <thead>
        <tr>
            <th>Name</th>
            <th>State</th>
            <th>Latitude</th>
            <th>Longitude</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var park in parks)
        {
            <tr>
                <td>@park.Name</td>
                <td>@park.State</td>
                <td>@park.Latitude</td>
                <td>@park.Longitude</td>
            </tr>
        }
    </tbody>
</table>

@code {
    private List<Park> parks = [];
    private FormModel model = new();
    private string? successMessage;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        parks = await ParkService.GetAllParksAsync();
    }

    private async Task HandleAddPark()
    {
        successMessage = null;
        errorMessage = null;
        try
        {
            await ParkService.AddParkAsync(model.Name!, model.State!, model.Latitude, model.Longitude, model.Description);
            parks = await ParkService.GetAllParksAsync();
            successMessage = $"{model.Name} added successfully.";
            model = new();
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to add park: {ex.Message}";
        }
    }

    private class FormModel
    {
        [System.ComponentModel.DataAnnotations.Required]
        public string? Name { get; set; }

        [System.ComponentModel.DataAnnotations.Required]
        public string? State { get; set; }

        public double Latitude { get; set; }
        public double Longitude { get; set; }
        public string? Description { get; set; }
    }
}
