@page "/"
@attribute [Authorize]
@rendermode InteractiveServer

@using System.Security.Claims
@using Microsoft.JSInterop
@using ParkTracker.Data.Models
@using ParkTracker.Services
@using ParkTracker.Components.Shared

@inject IParkService ParkService
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JS

@implements IDisposable

<PageTitle>Park Tracker</PageTitle>

<h1>My National Parks</h1>

<div class="mb-4 d-flex align-items-end justify-content-between">
    <div>
        <div class="visit-stats__numbers">
            <span class="visit-stats__count">@VisitedCount</span><span class="visit-stats__total"> / @parks.Count</span>
        </div>
        <div class="visit-stats__bar">
            <div class="visit-stats__fill" style="width: @ProgressPct%"></div>
        </div>
        <div class="visit-stats__label">@ProgressPct% explored</div>
    </div>
    <button class="btn btn-primary" @onclick="() => showModal = true">+ Add Visit</button>
</div>

<div id="map-container" style="height:600px;width:100%;border-radius:8px;"></div>

@if (showModal)
{
    <AddVisitModal Parks="parks"
                   PreselectedParkId="preselectedParkId"
                   OnVisitSaved="HandleVisitSaved"
                   OnClose="CloseModal" />
}

@code {
    private List<Park> parks = [];
    private string? currentUserId;
    private bool showModal = false;
    private int? preselectedParkId;
    private DotNetObjectReference<Home>? dotNetRef;

    private int VisitedCount => parks.Count(p => p.Visits.Any());
    private int ProgressPct => parks.Count > 0 ? VisitedCount * 100 / parks.Count : 0;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        currentUserId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        if (currentUserId is not null)
            parks = await ParkService.GetAllParksWithUserVisitsAsync(currentUserId);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            dotNetRef = DotNetObjectReference.Create(this);
            await InitializeMap();
        }
    }

    [JSInvokable]
    public async Task OpenAddVisitFromMap(int parkId)
    {
        preselectedParkId = parkId;
        showModal = true;
        await InvokeAsync(StateHasChanged);
    }

    private void CloseModal()
    {
        showModal = false;
        preselectedParkId = null;
    }

    public void Dispose()
    {
        dotNetRef?.Dispose();
    }

    private async Task InitializeMap()
    {
        await JS.InvokeVoidAsync("leafletInterop.initMap", "map-container", 39.5, -98.35, 4);
        await RefreshPins();
    }

    private async Task RefreshPins()
    {
        var pins = parks.Select(p => new
        {
            id = p.Id,
            name = p.Name,
            state = p.State,
            latitude = p.Latitude,
            longitude = p.Longitude,
            visited = p.Visits.Any(),
            visitDates = p.Visits.Select(v => v.VisitDate?.ToString("o")).ToArray()
        }).ToArray();

        await JS.InvokeVoidAsync("leafletInterop.clearPins");
        await JS.InvokeVoidAsync("leafletInterop.addPins", (object)pins, dotNetRef);
    }

    private async Task HandleVisitSaved()
    {
        showModal = false;
        if (currentUserId is not null)
            parks = await ParkService.GetAllParksWithUserVisitsAsync(currentUserId);
        await RefreshPins();
    }
}
